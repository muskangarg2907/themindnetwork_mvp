{
  "buildCommand": "node --no-deprecation node_modules/vite/bin/vite.js build",
  "outputDirectory": "dist",
  "headers": [
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "functions": {
    "api/admin.ts": { "maxDuration": 10 },
    "api/contact.ts": { "maxDuration": 10 },
    "api/generate.ts": { "maxDuration": 10 },
    "api/og-image.ts": { "maxDuration": 5 },
    "api/profiles.ts": { "maxDuration": 10 },
    "api/razorpay.ts": { "maxDuration": 10 },
    "api/snapshot.ts": { "maxDuration": 30 },
    "api/utils.ts": { "maxDuration": 10 }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/therapy-guide",
      "destination": "/therapy-guide.html"
    },
    {
      "source": "/((?!api).*)",
      "destination": "/index.html"
    }
  ]
}

